# Cleartext content of `test/dotenv` secret:
# s3cr3t
# user@example.com
#
# otpauth://totp/pass?secret=OTPS3CR3T
#
# ---
# url: https://example.com/
# api_key: APIK3Y123456
# name:
#   first: John
#   last: Doe
UNQUOTED=one
QUOTED='two'
DOUBLE_QUOTED="three"
PASSWORD=pass://test/dotenv/.password
LAST_NAME=pass://test/dotenv/.name.last

CRYSTAL_VERSION=1.20.1
